# Artist to scrape (used for Last.fm lookup)
ARTIST_NAME=Ashwin Azer

# Optional: override the Last.fm artist URL slug if the auto-derived slug is wrong
# (e.g. if the artist page lives at /music/Ashwin-Azer instead of /music/Ashwin+Azer)
# LASTFM_ARTIST_URL=

# Optional: delay in seconds between page requests (default: 1.0)
# SCRAPE_DELAY=1.0

# MusicBrainz MBID for the artist if already known
# (format: 8-4-4-4-12 hex, e.g. 12345678-1234-1234-1234-123456789012)
# ARTIST_MBID=

# Output directories
REPORTS_DIR=reports
EVIDENCE_DIR=evidence_packs
