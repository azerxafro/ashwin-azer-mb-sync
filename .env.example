# Spotify API credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Apple Music API credentials
# Generate a MusicKit key at https://developer.apple.com/account/resources/authkeys/list
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
# Path to the .p8 private key file downloaded from Apple Developer portal
APPLE_PRIVATE_KEY_PATH=path/to/AuthKey_XXXXXXXXXX.p8

# Target artist identifiers (pre-filled for Ashwin Azer)
SPOTIFY_ARTIST_ID=6M1VSmwtcuwS1DnvXTGk7P
APPLE_MUSIC_ARTIST_ID=1497428225

# Apple Music storefront (country code)
APPLE_MUSIC_STOREFRONT=in

# Output directories
REPORTS_DIR=reports
EVIDENCE_DIR=evidence_packs
